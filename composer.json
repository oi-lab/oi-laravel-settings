{
    "name": "oi-lab/oi-laravel-settings",
    "description": "Configuration settings management for Laravel with scoped values, typed casts and spatie/laravel-data value objects.",
    "type": "library",
    "keywords": [
        "laravel",
        "settings",
        "configuration",
        "spatie-laravel-data"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "OI Lab",
            "email": "olivier@olacombe.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/cache": "^11.0|^12.0|^13.0",
        "spatie/laravel-data": "^4.0"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "OiLab\\OiLaravelSettings\\": "src/",
            "OiLab\\OiLaravelSettings\\Database\\Factories\\": "database/factories/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "OiLab\\OiLaravelSettings\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OiLab\\OiLaravelSettings\\OiLaravelSettingsServiceProvider"
            ],
            "aliases": {
                "Settings": "OiLab\\OiLaravelSettings\\Facades\\Settings"
            }
        },
        "oi-lab": {
            "skills": [
                {
                    "name": "oilab-laravel-settings",
                    "description": "Configuration settings management for Laravel with scoped values, typed casts and spatie/laravel-data value objects.",
                    "path": "resources/stubs/ai-skill.md",
                    "rules": "resources/stubs/claude-rules.md",
                    "section": "oi-lab/oi-laravel-settings rules"
                }
            ]
        }
    },
    "scripts": {
        "sync-ai-skills": [
            "@php scripts/sync-ai-skills.php"
        ],
        "post-autoload-dump": [
            "@php scripts/sync-ai-skills.php"
        ],
        "test": [
            "@php vendor/bin/pest"
        ],
        "lint": [
            "@php vendor/bin/pint"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
